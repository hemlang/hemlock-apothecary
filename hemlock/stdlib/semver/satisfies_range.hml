import { satisfies, increment } from "@stdlib/semver";

let versions = ["1.0.0", "1.2.5", "1.3.0", "2.0.0-rc.1", "2.0.0"];
let range = "^1.2.0";

for (v in versions) {
    print(`${v} satisfies ${range}: ${satisfies(v, range)}`);
}

print("---");
print(`1.2.3 -> patch: ${increment("1.2.3", "patch")}`);
print(`1.2.3 -> minor: ${increment("1.2.3", "minor")}`);
print(`1.2.3 -> major: ${increment("1.2.3", "major")}`);

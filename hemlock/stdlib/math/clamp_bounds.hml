import { clamp, min, max } from "@stdlib/math";

let readings = [-5, 3, 12, 87, 150, 99, 0];
let lo = 0;
let hi = 100;

let lowest = readings[0];
let highest = readings[0];
for (r in readings) {
    print(`${r} -> ${clamp(r, lo, hi)}`);
    lowest = min(lowest, r);
    highest = max(highest, r);
}

print(`raw range: [${lowest}, ${highest}]`);
print(`clamp range: [${lo}, ${hi}]`);

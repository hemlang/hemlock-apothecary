import { from_rows, identity } from "@stdlib/matrix";

let m = from_rows([[1, 2, 3], [4, 5, 6]]);
let t = m.transpose();

for (let r = 0; r < 3; r++) {
    print(`t[${r}]: ${t.row(r).join(", ")}`);
}

let I3 = identity(3);
for (let r = 0; r < 3; r++) {
    print(`I[${r}]: ${I3.row(r).join(", ")}`);
}

import { from_date } from "@stdlib/datetime";

let holidays = [
    { name: "New Year",      date: [2026, 1, 1] },
    { name: "Independence",  date: [2026, 7, 4] },
    { name: "Christmas",     date: [2026, 12, 25] }
];

for (h in holidays) {
    let dt = from_date(h.date[0], h.date[1], h.date[2]);
    print(`${h.name} 2026 falls on a ${dt.weekday_name()}`);
}
